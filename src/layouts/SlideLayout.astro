---
import SlideHead from '../components/SlideHead.astro';
import SlideNav from '../components/slide-kit/SlideNav.astro';

export interface Props {
  title: string;
  context: string;
  description?: string;
  backHref: string;
  backLabel?: string;
  startHref: string;
  prevHref?: string;
  nextHref?: string;
  slideNumber: number;
  totalSlides: number
  isDraft?: boolean;
  isHidden?: boolean;
}

const {
  title,
  context,
  description = '',
  backHref,
  backLabel = 'Lecture',
  startHref,
  prevHref,
  nextHref,
  slideNumber,
  totalSlides,
  isDraft = false,
  isHidden = false,
} = Astro.props;


---
<html lang="en" class="antialiased break-words">
  <head>
    <SlideHead title={title} description={description} />
  </head>
  <body class="bg-main text-main">
    <div id="slide-root" class="slide-root bg-main text-main" style="--base-w: 1920; --base-h: 1080;">
      <div class="slide-stage">
        <div class="h-full min-h-0 grid grid-rows-[1fr_auto] gap-6 p-8">
          <div class="h-full min-h-0 overflow-hidden">
            <div class="prose max-w-none w-full h-full min-h-0 overflow-auto first:mt-0 last:mb-0">
              <slot />
            </div>
          </div>
          <SlideNav slideNumber={slideNumber} totalSlides={totalSlides} isDraft={isDraft} isHidden={isHidden} backHref={backHref} backLabel={backLabel} startHref={startHref} prevHref={prevHref} nextHref={nextHref} />
        </div>
      </div>
    </div>
    <script>
      (function() {
        var root = document.getElementById('slide-root');
        if (!root) return;
        var cs = getComputedStyle(root);
        var baseW = parseFloat(cs.getPropertyValue('--base-w')) || 1920;
        var baseH = parseFloat(cs.getPropertyValue('--base-h')) || 1080;
        var update = function() {
          var vw = window.innerWidth || document.documentElement.clientWidth || 0;
          var vh = window.innerHeight || document.documentElement.clientHeight || 0;
          var s = Math.min(vw / baseW, vh / baseH);
          var r = document.getElementById('slide-root');
          if (r) r.style.setProperty('--slide-scale', String(s));
        };
        update();
        window.addEventListener('resize', update, { passive: true });
      })();
    </script>
  </body>
</html>